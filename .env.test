# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999
OPENAI_API_KEY=sk-proj-testing1234

###> symfony/panther ###
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots
###< symfony/panther ###

# The end-to-end tests in tests/E2E drive the application in the dev environment, so that the web
# profiler with its Symfony AI panel is available - and so that the API keys of .env.local are used.
#
# These overrides live outside of the recipe block above on purpose: "composer recipes:update" would
# rewrite everything between its markers, and silently put the suite back into the panther env.
PANTHER_APP_ENV=dev
PANTHER_DEVTOOLS=0
